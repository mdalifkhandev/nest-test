generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Task {
    id          Int      @id @default(autoincrement())
    title       String
    discription String
    status      String   @default("pending")
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

model User {
    id        Int      @id @default(autoincrement())
    name      String
    email     String   @unique
    password  String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
